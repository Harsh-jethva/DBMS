<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1600" height="1000" viewBox="0 0 1600 1000">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0a0a0a"/>
      <stop offset="0.55" stop-color="#101011"/>
      <stop offset="1" stop-color="#0a0a0a"/>
    </linearGradient>
    <radialGradient id="a" cx="70%" cy="30%" r="70%">
      <stop offset="0" stop-color="#FF5C00" stop-opacity="0.32"/>
      <stop offset="1" stop-color="#FF5C00" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="b" cx="25%" cy="60%" r="70%">
      <stop offset="0" stop-color="#4DFFDF" stop-opacity="0.18"/>
      <stop offset="1" stop-color="#4DFFDF" stop-opacity="0"/>
    </radialGradient>
    <filter id="soft" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="22"/>
    </filter>
  </defs>
  <rect width="1600" height="1000" fill="url(#bg)"/>
  <circle cx="1140" cy="300" r="560" fill="url(#a)"/>
  <circle cx="420" cy="650" r="620" fill="url(#b)"/>
  <g filter="url(#soft)" opacity="0.7">
    <rect x="980" y="470" width="520" height="280" rx="40" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.12)"/>
    <rect x="1040" y="520" width="400" height="22" rx="11" fill="rgba(255,255,255,0.16)"/>
    <rect x="1040" y="562" width="290" height="18" rx="9" fill="rgba(255,255,255,0.12)"/>
    <rect x="1040" y="610" width="160" height="52" rx="26" fill="rgba(77,255,223,0.16)" stroke="rgba(77,255,223,0.26)"/>
  </g>
  <text x="160" y="320" fill="#f3f4f6" font-family="Syne, Inter, system-ui" font-size="76" font-weight="800" letter-spacing="-2">VISTORA LUXE</text>
  <text x="160" y="388" fill="rgba(243,244,246,0.68)" font-family="Inter, system-ui" font-size="22">Luxury e-commerce storefront concept</text>
  <g opacity="0.18">
    <path d="M160 190 H 1440" stroke="#ffffff" stroke-width="2"/>
    <path d="M160 820 H 1440" stroke="#ffffff" stroke-width="2"/>
  </g>
</svg>
