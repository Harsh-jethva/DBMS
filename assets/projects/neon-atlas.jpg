<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1600" height="1000" viewBox="0 0 1600 1000">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#070707"/>
      <stop offset="0.5" stop-color="#0c0c0d"/>
      <stop offset="1" stop-color="#070707"/>
    </linearGradient>
    <radialGradient id="glow1" cx="35%" cy="35%" r="70%">
      <stop offset="0" stop-color="#4DFFDF" stop-opacity="0.28"/>
      <stop offset="1" stop-color="#4DFFDF" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="glow2" cx="75%" cy="55%" r="75%">
      <stop offset="0" stop-color="#FF5C00" stop-opacity="0.18"/>
      <stop offset="1" stop-color="#FF5C00" stop-opacity="0"/>
    </radialGradient>
    <filter id="blur" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="14"/>
    </filter>
  </defs>
  <rect width="1600" height="1000" fill="url(#bg)"/>
  <circle cx="560" cy="330" r="600" fill="url(#glow1)"/>
  <circle cx="1180" cy="560" r="650" fill="url(#glow2)"/>
  <g opacity="0.2">
    <path d="M220 260 C 520 160, 820 360, 1040 260 S 1400 220, 1480 340" fill="none" stroke="#ffffff" stroke-width="2"/>
    <path d="M220 720 C 520 620, 820 820, 1040 720 S 1400 680, 1480 800" fill="none" stroke="#ffffff" stroke-width="2"/>
  </g>
  <g filter="url(#blur)" opacity="0.7">
    <circle cx="1080" cy="420" r="140" fill="rgba(77,255,223,0.10)"/>
    <circle cx="1080" cy="420" r="106" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.14)"/>
    <path d="M980 420 H1180" stroke="rgba(77,255,223,0.6)" stroke-width="4" stroke-linecap="round"/>
    <path d="M1080 320 V520" stroke="rgba(255,92,0,0.45)" stroke-width="4" stroke-linecap="round"/>
  </g>
  <text x="160" y="320" fill="#f3f4f6" font-family="Syne, Inter, system-ui" font-size="74" font-weight="800" letter-spacing="-2">Neon Atlas</text>
  <text x="160" y="388" fill="rgba(243,244,246,0.68)" font-family="Inter, system-ui" font-size="22">Interactive portfolio / 3D storytelling concept</text>
</svg>
